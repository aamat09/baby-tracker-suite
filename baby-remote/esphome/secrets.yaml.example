# Copy to secrets.yaml and fill in your values, then flash with:
#   esphome run baby_remote.yaml
# secrets.yaml is gitignored — never commit your real credentials.

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# MQTT broker the remote publishes button events to (e.g. an EMQX/Mosquitto
# host that Home Assistant or n8n also listens on).
mqtt_broker: "homelab.local"        # IP or hostname of your broker
mqtt_username: "mqtt_user"
mqtt_password: "YourMqttPassword"
