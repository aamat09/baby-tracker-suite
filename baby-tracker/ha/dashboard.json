              "content": "{% set entries = state_attr('sensor.baby_log', 'entries') %}\n{% if entries %}\n{% for e in entries %}\n{% if e.event_type is defined %}\n{% if e.event_type == 'feed' and e.event_subtype == 'breast' %}🤱 **Breast** — {{ e.time }}\n{% elif e.event_type == 'feed' and e.event_subtype == 'bottle' %}🍼 **Bottle** — {{ e.time }}\n{% elif e.event_type == 'feed' and e.event_subtype == 'solid' %}🥄 **Solid** — {{ e.time }}\n{% elif e.event_type == 'pump' and e.event_subtype == 'left' %}🫙 **Pump L** — {{ e.time }}\n{% elif e.event_type == 'pump' and e.event_subtype == 'right' %}🫙 **Pump R** — {{ e.time }}\n{% elif e.event_type == 'diaper' and e.event_subtype == 'change' %}🔄 **Diaper change** — {{ e.time }}\n{% elif e.event_type == 'diaper' and e.event_subtype == 'pee' %}💛 **Pee** — {{ e.time }}\n{% elif e.event_type == 'diaper' and e.event_subtype == 'poop' %}💩 **Poop** — {{ e.time }}\n{% elif e.event_type == 'diaper' and e.event_subtype == 'both' %}🧷 **Pee+Poop** — {{ e.time }}\n{% elif e.event_type == 'sleep' and e.event_subtype == 'start' %}😴 **Sleep start** — {{ e.time }}\n{% elif e.event_type == 'sleep' and e.event_subtype == 'end' %}⏰ **Sleep end** — {{ e.time }}\n{% elif e.event_type == 'bath' %}🛁 **Bath** — {{ e.time }}\n{% elif e.event_type == 'medicine' %}💊 **Medicine** — {{ e.time }}\n{% elif e.event_type == 'tummy_time' %}🤸 **Tummy time** — {{ e.time }}\n{% elif e.event_type == 'weight' %}⚖️ **Weight** — {{ e.time }}\n{% elif e.event_type == 'note' %}📝 **Note** — {{ e.note }} *({{ e.time }})*\n{% else %}👶 **{{ e.event_type }}** — {{ e.time }}\n{% endif %}\n{% endif %}\n{% endfor %}\n{% else %}\n*No entries yet.*\n{% endif %}"
